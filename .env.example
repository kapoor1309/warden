# ---- Band platform (same for every agent) ----
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# ---- WHO ARE YOU? (per-developer) ----
# Each developer registers their OWN 6 Band agents under their OWN namespace and
# keeps their OWN .env (gitignored). Handles are built as {prefix}/{slug}, so the
# SAME code runs for either of you — only this file differs.
#   Yash    -> BAND_HANDLE_PREFIX=yashb967      (agents: yashb967/invoice-intake, ...)
#   Parshiv -> BAND_HANDLE_PREFIX=parshiv.kapoor (agents: parshiv.kapoor/invoice-intake, ...)
# Slugs (fixed): invoice-intake, po-matcher, approver, warden, investigator, enforcer, payer
# After filling the ids/keys below, run:  python scripts/check_handles.py
BAND_HANDLE_PREFIX=

# HMAC secret for the deterministic pay-gate sign-off (any random string; keep private).
WARDEN_SIGNING_SECRET=

# ---- LLM providers ----
# Finance crew runs through AI/ML API (OpenAI-compatible base url + key).
OPENAI_API_KEY=
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
# Investigator's reasoning runs on an open model via Featherless (partner prize).
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
ANTHROPIC_API_KEY=

# Model choices (small + cheap; change here, not in code)
AIML_MODEL=gpt-4o-mini
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct

# ---- Per-agent Band credentials (register each in app.band.ai, paste here) ----
# API key is shown ONCE on creation. Agent UUID is bottom-right of the agent page.
INTAKE_AGENT_ID=
INTAKE_API_KEY=

MATCHER_AGENT_ID=
MATCHER_API_KEY=

APPROVER_AGENT_ID=
APPROVER_API_KEY=

WARDEN_AGENT_ID=
WARDEN_API_KEY=

INVESTIGATOR_AGENT_ID=
INVESTIGATOR_API_KEY=

ENFORCER_AGENT_ID=
ENFORCER_API_KEY=

# ---- Showcase agents (add only once core six work) ----
PAYER_AGENT_ID=
PAYER_API_KEY=

THREAT_INTEL_AGENT_ID=
THREAT_INTEL_API_KEY=

REPORTER_AGENT_ID=
REPORTER_API_KEY=
